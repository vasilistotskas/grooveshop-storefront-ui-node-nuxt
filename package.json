{
  "name": "grooveshop-storefront-ui-node-nuxt",
  "version": "3.142.5",
  "description": "Grooveshop Storefront UI Node Nuxt",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/vasilistotskas/grooveshop-storefront-ui-node-nuxt.git"
  },
  "author": "vasilistotskas",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vasilistotskas/grooveshop-storefront-ui-node-nuxt/issues"
  },
  "homepage": "https://github.com/vasilistotskas/grooveshop-storefront-ui-node-nuxt#readme",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:all": "ncu -u && npm i && npm run build && npm run lint && npm run dev",
    "prepare": "nuxt prepare && (npx skilld prepare || true)",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "serve": "serve dist/",
    "lint": "eslint . --fix",
    "lint:ci": "eslint . --cache",
    "typecheck": "nuxt typecheck",
    "cleanup": "nuxt cleanup",
    "analyze": "npx nuxt analyze",
    "test": "vitest run",
    "test:ci": "vitest run --project=unit --project=nuxt --coverage",
    "test:coverage": "vitest run --coverage",
    "openapi-ts": "openapi-ts",
    "semantic-release": "semantic-release",
    "generate:schema": "node scripts/fetch-schema.mjs",
    "sync:schema": "node scripts/sync-schema-yml.mjs",
    "trivy-scan": "trivy fs . --severity HIGH,CRITICAL --skip-dirs node_modules,dist,.output,.nuxt --exit-code 1"
  },
  "dependencies": {
    "@internationalized/date": "3.12.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.3.1",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.3.0",
    "@nuxt/ui": "4.9.0",
    "@nuxtjs/i18n": "10.4.0",
    "@nuxtjs/leaflet": "1.3.2",
    "@nuxtjs/seo": "5.3.2",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/typography": "0.5.20",
    "@vueuse/nuxt": "14.3.0",
    "better-sqlite3": "12.11.1",
    "defu": "6.1.7",
    "evlog": "2.20.0",
    "h3": "1.15.11",
    "isomorphic-dompurify": "3.18.0",
    "leaflet": "1.9.4",
    "leaflet.markercluster": "1.5.3",
    "lottie-web": "5.13.0",
    "magic-string": "0.30.21",
    "nuxt": "4.4.8",
    "nuxt-ai-ready": "1.5.4",
    "nuxt-auth-utils": "0.5.29",
    "ofetch": "1.5.1",
    "pinia": "3.0.4",
    "redis": "6.1.0",
    "rss": "1.2.2",
    "tailwindcss": "4.3.2",
    "ufo": "1.6.4",
    "unstorage": "1.17.5",
    "vue": "3.5.39",
    "vue-i18n": "11.4.6",
    "vue-router": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@headlessui/vue": "1.7.23",
    "@hey-api/openapi-ts": "0.99.0",
    "@iconify-json/ant-design": "1.2.8",
    "@iconify-json/fa-solid": "1.2.2",
    "@iconify-json/fa6-solid": "1.2.4",
    "@iconify-json/heroicons": "1.2.3",
    "@iconify-json/heroicons-outline": "1.2.1",
    "@iconify-json/heroicons-solid": "1.2.1",
    "@iconify-json/lucide": "1.2.116",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/unjs": "1.2.4",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/hints": "1.1.3",
    "@nuxt/kit": "4.4.8",
    "@nuxt/schema": "4.4.8",
    "@nuxt/test-utils": "4.0.3",
    "@nuxt/types": "2.18.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.9",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@stripe/stripe-js": "9.9.0",
    "@testing-library/jest-dom": "6.9.1",
    "@types/dompurify": "3.2.0",
    "@types/leaflet": "1.9.21",
    "@types/leaflet.markercluster": "1.5.6",
    "@types/node": "26.1.1",
    "@types/rss": "0.0.32",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "@vueuse/core": "14.3.0",
    "@vueuse/integrations": "14.3.0",
    "@vueuse/shared": "14.3.0",
    "eslint": "10.7.0",
    "eslint-plugin-better-tailwindcss": "4.6.1",
    "happy-dom": "20.10.6",
    "semantic-release": "25.0.6",
    "typescript": "6.0.3",
    "undici": "8.7.0",
    "vite": "8.1.4",
    "vite-plugin-eslint2": "5.3.0",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": ".output",
              "label": "Output"
            }
          ]
        }
      ]
    ]
  },
  "packageManager": "pnpm@11.11.0"
}
